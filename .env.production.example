# =============================================================================
# Production environment TEMPLATE for the single-VM deploy (docker-compose.prod.yml).
#
# Copy to `.env` and fill in YOUR values:   cp .env.production.example .env
# `.env` is gitignored — NEVER commit real values. Placeholders only here.
#
# This stack is SELF-HOSTED: Postgres + Redis run as the `db` and `redis` containers
# in docker-compose.prod.yml (data persists in named volumes). To use managed Neon /
# Upstash instead, point DATABASE_URL / REDIS_URL / SYNC_PG_DSN at them and ignore the
# db/redis services.
#
# Secrets (DB password, tokens) live ONLY in `.env` on the server. Service-account KEYS
# are FILES under ./secrets/ (gitignored), never env vars:
#   ./secrets/firebase-admin.json   — Firebase Admin (token verification)   [required]
#   ./secrets/bq-reader.json        — BigQuery READER (a DIFFERENT identity) [optional]
# =============================================================================

ENV=production

# ── Self-hosted Postgres (the `db` service) ──────────────────────────────────
# These configure the db container AND must match DATABASE_URL / SYNC_PG_DSN below.
POSTGRES_USER=prometheus
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=prometheus
PG_HOST_PORT=5432          # host-only port for db access/debugging (bound to 127.0.0.1)

# App connection — asyncpg driver, pointing at the in-network `db` host (no TLS needed
# inside the compose network). Keep USER/PASSWORD/DB in sync with the POSTGRES_* above.
DATABASE_URL=postgresql+asyncpg://prometheus:CHANGE_ME_strong_db_password@db:5432/prometheus

# Same database in libpq form — used by the daily sync subprocess (asyncpg form won't
# work for it). Single-role deploy: same credentials as DATABASE_URL.
SYNC_PG_DSN=postgresql://prometheus:CHANGE_ME_strong_db_password@db:5432/prometheus

# ── Self-hosted Redis (the `redis` service) ──────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App ──────────────────────────────────────────────────────────────────────
# Exact public origin(s) of the dashboard, comma-separated, NO wildcards:
CORS_ORIGINS=https://your-domain.example

# Optional: a deployed Cloud Run Job execution endpoint for the sync. Leave blank to run
# the sync IN the backend container (needs ./secrets/bq-reader.json + SYNC_PG_DSN above).
SYNC_TRIGGER_URL=
SYNC_TRIGGER_TOKEN=

# NOTE: the BigQuery key PATH (BQ_CREDENTIALS_PATH=/secrets/bq-reader.json) is set in
# docker-compose.prod.yml, not here. The non-secret sync settings — GCP project, BigQuery
# view, schedule time/timezone, and the on/off toggle — are configured in the app's
# admin → Integration tab (stored in the DB), NOT as env vars.

# ── Frontend build args (PUBLIC — inlined into the client bundle at build time) ─
# The Firebase web config is public by design; these are NOT secrets. Still, do not
# commit real values. NEXT_PUBLIC_API_BASE_URL is the dashboard's own origin — the
# app calls it at `/api/v1/...`, which nginx proxies to the backend.
NEXT_PUBLIC_API_BASE_URL=https://your-domain.example
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
