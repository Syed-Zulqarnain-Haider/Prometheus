# =============================================================================
# Production environment TEMPLATE for the single-VM deploy (docker-compose.prod.yml).
#
# Copy to `.env` and fill in YOUR values:   cp .env.production.example .env
# `.env` is gitignored — NEVER commit real values. Placeholders only here.
# Real secrets (DB/Redis passwords, tokens) belong in `.env` on the server, never
# in git. The Firebase Admin key is a FILE at ./secrets/firebase-admin.json (also
# gitignored), not an env var.
# =============================================================================

# ── Backend (loaded into the API container via env_file) ─────────────────────
ENV=production

# Neon pooled Postgres — asyncpg driver, TLS required:
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require

# Upstash Redis — TLS (rediss://):
REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# Exact public origin(s) of the dashboard, comma-separated, NO wildcards:
CORS_ORIGINS=https://your-domain.example

# Optional — on-demand sync trigger + BigQuery project. Leave blank if unused.
BIGQUERY_PROJECT=
SYNC_TRIGGER_URL=
SYNC_TRIGGER_TOKEN=

# ── Frontend build args (PUBLIC — inlined into the client bundle at build time) ─
# The Firebase web config is public by design; these are NOT secrets. Still, do not
# commit real values. NEXT_PUBLIC_API_BASE_URL is the dashboard's own origin — the
# app calls it at `/api/v1/...`, which nginx proxies to the backend.
NEXT_PUBLIC_API_BASE_URL=https://your-domain.example
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
