# Keep the image small and free of local cruft / secrets.
.venv/
venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
tests/
# NOTE: scripts/ (create_admin.py) and sync/ are intentionally INCLUDED in the image
# so admin provisioning and the daily sync can run via the same container.
.env
.env.*
!.env.example
dump.rdb
README.md.orig
