# Copy to .env for local development. NEVER commit a real .env (see .gitignore).
# In production these are provided by GCP Secret Manager / Cloud Run env, not a file.

ENV=development

# Async SQLAlchemy DSN (note the +asyncpg driver).
DATABASE_URL=postgresql+asyncpg://prometheus:prometheus@localhost:5432/prometheus

REDIS_URL=redis://localhost:6379/0

# Exact frontend origin(s), comma-separated. No wildcards.
CORS_ORIGINS=http://localhost:3000

# Firebase project id used to verify ID-token audience. In production set this on
# Cloud Run; locally, firebase-admin reads GOOGLE_APPLICATION_CREDENTIALS instead
# (see docs/RUNBOOK-LOCAL.md). Leave blank if your local flow doesn't verify tokens.
# GOOGLE_CLOUD_PROJECT=your-firebase-project-id
